# Always serve index.html for the root and for directories
DirectoryIndex index.html

# Disable directory listing — no "Index of /" on mobile or desktop
Options -Indexes

# Core Web Vitals: cache static assets for fast repeat visits (mobile & desktop)
<IfModule mod_expires.c>
  ExpiresActive On
  ExpiresByType text/html "access plus 1 hour"
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType image/svg+xml "access plus 1 month"
  ExpiresByType image/png "access plus 1 month"
  ExpiresByType image/jpeg "access plus 1 month"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
</IfModule>
<IfModule mod_headers.c>
  <FilesMatch "\.(html|htm)$">
    Header set Cache-Control "public, max-age=3600"
  </FilesMatch>
  <FilesMatch "\.(css|js|svg|png|jpg|jpeg|woff2|woff)$">
    Header set Cache-Control "public, max-age=2592000"
  </FilesMatch>
</IfModule>
